        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ta aplikacja zostala przeniesiona na zewnetrzne przechowywanie, ale nie jest zablokowana. Aktualizacje w aplikacji moga usunac zewnetrzna aplikacje. Zaleca sie powrot i ponowna migracje w trybie blokady."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Este app foi migrado para armazenamento externo mas nao esta bloqueado. Atualizacoes dentro do app podem excluir o app externo. Recomenda-se voltar ao local e migrar novamente no modo bloqueado."
          }

        "zh-martian": {
          "stringUnit": {
            "state": "translated",
            "value": "е∞ЖгАМ%@гАНињБзІїеИ∞е§ЦйГ®е≠ШеВ®%@гАВ\n\nжЇРиЈѓеЊДпЉЪ%@\nзЫЃж†ЗиЈѓеЊДпЉЪ%@\n\nињБзІїеЃМжИРеРОпЉМеОЯиЈѓеЊДе∞ЖиЗ™еК®еПШжИРзђ¶еПЈйУЊжО•пЉМзЫЄеЕ≥еЈ•еЕЈжЧ†йЬАдїїдљХдњЃжФєеН≥еПѓзїІзї≠дљњзФ®гАВ"
          }
        }
      }
    },
    "дї•дЄЛеЇФзФ®жФѓжМБиЗ™еК®жЫіжЦ∞пЉМињБзІїеРОеЇФзФ®еЖЕжЫіжЦ∞еПѓиГљеѓЉиЗіе§ЦйГ®еЇФзФ®дЄҐе§±пЉЪ\\n\\n%@\\n\\nвАҐ йФБеЃЪињБзІїпЉЪе§ЦйГ®еЇФзФ®иҐЂйФБеЃЪпЉМйШїж≠ҐжЫіжЦ∞з†іеЭПпЉМйЬАйАЪињЗ AppPorts ињБеЫЮеРОжЫіжЦ∞\\nвАҐ йЭЮйФБеЃЪињБзІїпЉЪдЄНйФБеЃЪе§ЦйГ®еЇФзФ®пЉМеЇФзФ®еЖЕжЫіжЦ∞еПѓиГљеИ†йЩ§е§ЦйГ®еЇФзФ®\\n\\nеїЇиЃЃйАЙжЛ©йФБеЃЪињБзІїдї•дњЭжК§жХ∞жНЃеЃЙеЕ®гАВ": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The following apps support auto-updates. After migration, in-app updates may cause external app data loss:\n\n%@\n\nвАҐ Locked Migration: External app is locked to prevent update damage; requires moving back via AppPorts to update\nвАҐ Unlocked Migration: External app is not locked; in-app updates may delete the external app\n\nLocked migration is recommended to protect data safety."
          }
        },
        "zh-Hans": {
          "stringUnit": {

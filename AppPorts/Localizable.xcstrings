    "ж≠§еЇФзФ®дљњзФ® Sparkle ж°ЖжЮґиЗ™еК®жЫіжЦ∞гАВињБзІїеИ∞е§ЦйГ®е≠ШеВ®еРОпЉМеЇФзФ®еЖЕжЫіжЦ∞еПѓиГљеѓЉиЗіе§ЦйГ®еЇФзФ®дЄҐе§±гАВеїЇиЃЃдљњзФ®йФБеЃЪињБзІїдњЭжК§жХ∞жНЃеЃЙеЕ®гАВ": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This app uses the Sparkle framework for auto-updates. After migrating to external storage, in-app updates may cause external app data loss. Locked migration is recommended to protect data safety."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "ж≠§еЇФзФ®дљњзФ® Sparkle ж°ЖжЮґиЗ™еК®жЫіжЦ∞гАВињБзІїеИ∞е§ЦйГ®е≠ШеВ®еРОпЉМеЇФзФ®еЖЕжЫіжЦ∞еПѓиГљеѓЉиЗіе§ЦйГ®еЇФзФ®дЄҐе§±гАВеїЇиЃЃдљњзФ®йФБеЃЪињБзІїдњЭжК§жХ∞жНЃеЃЙеЕ®гАВ"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "ж≠§еЇФзФ®дљњзФ® Sparkle ж°ЖжЮґиЗ™еК®жЫіжЦ∞гАВињБзІїеИ∞е§ЦйГ®е≠ШеВ®еРОпЉМеЇФзФ®еЖЕжЫіжЦ∞еПѓиГљеѓЉиЗіе§ЦйГ®еЇФзФ®дЄҐе§±гАВеїЇиЃЃдљњзФ®йФБеЃЪињБзІїдњЭжК§жХ∞жНЃеЃЙеЕ®гАВ"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "yastakhdim hada alttatbiq eayilat Sparkle lilttajir altaakudi. bad alttahil ealaa alttakhzin alkhariji, qad yasabbib altaajir fi dakhil alttatbiq fiadaan alttatbiq alkhariji. yuwssa bialttahil almuqlad lihmiayat amn albayanaat."
          }
        },
        "br": {
          "stringUnit": {
            "state": "translated",
            "value": "This app uses the Sparkle framework for auto-updates."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese App verwendet das Sparkle-Framework fuer automatische Updates. Nach der Migration auf externen Speicher koennen In-App-Updates zum Verlust der externen App fuehren. Gesperrte Migration wird zum Schutz der Datensicherheit empfohlen."
          }
        },
        "eo": {
          "stringUnit": {
            "state": "translated",
            "value": "Chi tiu aplikacio uzas la Sparkle-framkon por axtomataj ghisdatighoj. Post migrado al ekstera konservejo, en-aplikaj ghisdatighoj povas kauxi perdon de la ekstera aplikacxio. Shlosita migrado estas rekomendata por protekti datuman sekurecon."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta app usa el framework Sparkle para actualizaciones automaticas. Despues de migrar al almacenamiento externo, las actualizaciones dentro de la app pueden causar la perdida de la app externa. Se recomienda la migracion bloqueada para proteger la seguridad de los datos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette application utilise le framework Sparkle pour les mises a jour automatiques. Apres migration vers le stockage externe, les mises a jour integrees peuvent entrainer la perte de l'application externe. La migration verrouillee est recommandee pour proteger la securite des donnees."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "yah app svaachlit apdet ke lie Sparkle framework ka upyog karta hai. baahari storaej mein maigreshan ke baad, app ke bheetar apdet baahari app ke nukasaan ka kaaran ban sakte hain. daeta suraksha ke lie lokd maigreshan ki sifaarish ki jaati hai."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplikasi ini menggunakan framework Sparkle untuk pembaruan otomatis. Setelah migrasi ke penyimpanan eksternal, pembaruan dalam aplikasi dapat menyebabkan kehilangan aplikasi eksternal. Migrasi terkunci direkomendasikan untuk melindungi keamanan data."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa app utilizza il framework Sparkle per gli aggiornamenti automatici. Dopo la migrazione allo storage esterno, gli aggiornamenti in-app possono causare la perdita dell'app esterna. La migrazione bloccata e consigliata per proteggere la sicurezza dei dati."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "гБУгБЃгВҐгГЧгГ™гБѓSparkleгГХгГђгГЉгГ†гГѓгГЉгВѓгВТдљњзФ®гБЧгБ¶иЗ™еЛХжЫіжЦ∞гБЧгБЊгБЩгАВе§ЦйГ®гВєгГИгГђгГЉгВЄгБЂзІїи°МгБЩгВЛгБ®гАБгВҐгГЧгГ™еЖЕжЫіжЦ∞гБЂгВИгБ£гБ¶е§ЦйГ®гВҐгГЧгГ™гБМе§±гВПгВМгВЛеПѓиГљжАІгБМгБВгВКгБЊгБЩгАВгГЗгГЉгВњеЃЙеЕ®гБЃгБЯгВБгАБгГ≠гГГгВѓзІїи°МгВТжО®е•®гБЧгБЊгБЩгАВ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "мЭі мХ±мЭА Sparkle нФДл†ИмЮДмЫМнБђл•Љ мВђмЪ©нХШмЧђ мЮРлПЩ мЧЕлН∞мЭінКЄлР©лЛИлЛ§. мЩЄлґА мК§нЖ†л¶ђмІАл°Ь лІИмЭікЈЄл†ИмЭімЕШнХЬ нЫД мХ± лВі мЧЕлН∞мЭінКЄл°Ь мЭЄнХі мЩЄлґА мХ±мЭі мЖРмЛ§лР† мИШ мЮИмКµлЛИлЛ§. лН∞мЭінД∞ мХИм†ДмЭД мЬДнХі мЮ†кЄИ лІИмЭікЈЄл†ИмЭімЕШмЭД кґМмЮ•нХ©лЛИлЛ§."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze app gebruikt het Sparkle-framework voor automatische updates. Na migratie naar externe opslag kunnen in-app updates verlies van de externe app veroorzaken. Vergrendelde migratie wordt aanbevolen voor gegevensbeveiliging."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ta aplikacja uzywa frameworka Sparkle do automatycznych aktualizacji. Po migracji na zewnetrzne przechowywanie aktualizacje w aplikacji moga spowodowac utrate zewnetrznej aplikacji. Zalecana jest zablokowana migracja w celu ochrony danych."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Este app usa o framework Sparkle para atualizacoes automaticas. Apos a migracao para armazenamento externo, atualizacoes dentro do app podem causar a perda do app externo. Migracao bloqueada e recomendada para proteger a seguranca dos dados."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Eto prilozhenie ispol'zuet framework Sparkle dlya avtomaticheskikh obnovleniy. Posle migratsii na vneshneye khranilishche obnovleniya vnutri prilozheniya mogut privesti k potere vneshnego prilozheniya. Rekomenduyetsya zablokirovannaya migratsiya dlya zashchity dannykh."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "app ni chuay Sparkle framework samrap abpdet atomatik. hang yai pai yang tang kep nork, kan abpdet nai app ja thang hai app nork song hai. naenae kan yai khorwng mod lock phro khwam plod phai khong khoramai"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu uygulama otomatik guncellemeler icin Sparkle framework kullanir. Harici depolamaya tasindiktan sonra uygulama ici guncellemeler harici uygulamanin kaybolmasina neden olabilir. Veri guvenligi icin kilitli tasima onerilir."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ung dung nay su dung Sparkle framework de tu dong cap nhat. Sau khi di chuyen sang bo ngoai, cap nhat trong ung dung co the gay mat ung dung ben ngoai. Nen su dung di chuyen khoa de bao ve an toan du lieu."
          }
        },
        "zh-martian": {
          "stringUnit": {
            "state": "translated",
            "value": "ж≠§еЇФзФ®дљњзФ® Sparkle ж°ЖжЮґиЗ™еК®жЫіжЦ∞гАВињБзІїеИ∞е§ЦйГ®е≠ШеВ®еРОпЉМеЇФзФ®еЖЕжЫіжЦ∞еПѓиГљеѓЉиЗіе§ЦйГ®еЇФзФ®дЄҐе§±гАВеїЇиЃЃдљњзФ®йФБеЃЪињБзІїдњЭжК§жХ∞жНЃеЃЙеЕ®гАВ"
          }
        }
      }
    },
    "ж≠§еЇФзФ®еЯЇдЇО Electron ж°ЖжЮґпЉМжФѓжМБиЗ™еК®жЫіжЦ∞гАВињБзІїеИ∞е§ЦйГ®е≠ШеВ®еРОпЉМеЇФзФ®еЖЕжЫіжЦ∞еПѓиГљеѓЉиЗіе§ЦйГ®еЇФзФ®дЄҐе§±гАВеїЇиЃЃдљњзФ®йФБеЃЪињБзІїдњЭжК§жХ∞жНЃеЃЙеЕ®гАВ": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This app is based on the Electron framework and supports auto-updates. After migrating to external storage, in-app updates may cause external app data loss. Locked migration is recommended to protect data safety."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",

    "需要时，可随时将应用一键完整迁回本地 /Applications 目录。": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "انقل التطبيقات فورًا إلى /Applications المحلي عند الحاجة."
          }
        },
        "br": {
          "stringUnit": {
            "state": "translated",
            "value": "⠠⠊⠝⠎⠞⠁⠝⠞⠇⠽ ⠍⠕⠧⠑ ⠁⠏⠏⠎ ⠃⠁⠉⠅ ⠞⠕ ⠇⠕⠉⠁⠇ ⠌⠠⠁⠏⠏⠇⠊⠉⠁⠞⠊⠕⠝⠎ ⠺⠓⠑⠝⠑⠧⠑⠗ ⠝⠑⠑⠙⠑⠙⠲"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verschieben Sie Apps bei Bedarf sofort zurück in den lokalen /Applications-Ordner."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Instantly move apps back to local /Applications whenever needed."
          }
        },
        "eo": {
          "stringUnit": {
            "state": "translated",
            "value": "Tuj movu aplikaĵojn reen al loka /Applications kiam necese."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mueve instantáneamente las apps de vuelta a /Applications local cuando sea necesario."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Déplacez instantanément les applications vers /Applications localement si nécessaire."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जब भी आवश्यकता हो ऐप्स को तुरंत स्थानीय /Applications में वापस ले जाएं।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Segera pindahkan aplikasi kembali ke /Applications lokal kapan pun diperlukan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sposta istantaneamente le app in /Applications locale quando necessario."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "必要に応じて、いつでもアプリをローカルの/Applicationsディレクトリに戻せます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "필요할 때마다 앱을 즉시 로컬 /Applications로 다시 이동하십시오."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Verplaats apps indien nodig direct terug naar lokaal /Applications."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Natychmiast przenieś aplikacje z powrotem do lokalnego /Applications w razie potrzeby."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Mova instantaneamente apps de volta para /Applications local quando necessário."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мгновенно переносите приложения обратно в /Applications при необходимости."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ย้ายแอปกลับไปที่ /Applications ในเครื่องได้ทันทีเมื่อจำเป็น"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gerektiğinde uygulamaları anında yerel /Applications klasörüne geri taşıyın."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Di chuyển ứng dụng ngay lập tức trở lại /Applications cục bộ bất cứ khi nào cần thiết."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "需要时，可随时将应用一键完整迁回本地 /Applications 目录。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "需要時，可隨時將應用程式一鍵完整遷回本地 /Applications 目錄。"
          }
        }
      }
    },

    "应用需要读写 /Applications 目录才能工作。请在系统设置中开启。": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحتاج التطبيق إلى الوصول للقراءة/الكتابة إلى /Applications. يرجى التمكين في الإعدادات."
          }
        },
        "br": {
          "stringUnit": {
            "state": "translated",
            "value": "⠠⠁⠏⠏ ⠝⠑⠑⠙⠎ ⠗⠑⠁⠙⠌⠺⠗⠊⠞⠑ ⠁⠉⠉⠑⠎⠎ ⠞⠕ ⠌⠠⠁⠏⠏⠇⠊⠉⠁⠞⠊⠕⠝⠎⠲ ⠠⠏⠇⠑⠁⠎⠑ ⠑⠝⠁⠃⠇⠑ ⠊⠝ ⠠⠎⠽⠎⠞⠑⠍ ⠠⠎⠑⠞⠞⠊⠝⠛⠎⠲"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "App benötigt Lese-/Schreibzugriff auf /Applications. Bitte in den Systemeinstellungen aktivieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "App needs read/write access to /Applications. Please enable in System Settings."
          }
        },
        "eo": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplikaĵo bezonas legi/skribi aliron al /Applications. Bonvolu ebligi en Sistemaj Agordoj."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La app necesita acceso de lectura/escritura a /Applications. Habilítalo en Configuración."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'app a besoin d'un accès lecture/écriture à /Applications. Activez dans les Réglages."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ऐप को /Applications तक पहुंच की आवश्यकता है। कृपया सेटिंग्स में सक्षम करें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplikasi memerlukan akses baca/tulis ke /Applications. Harap aktifkan di Pengaturan Sistem."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'app necessita di accesso lettura/scrittura a /Applications. Abilita nelle Impostazioni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリには/Applicationsへの読み書きアクセスが必要です。設定で有効にしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "앱에 /Applications에 대한 읽기/쓰기 액세스가 필요합니다. 시스템 설정에서 활성화하십시오."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "App heeft lees-/schrijftoegang nodig tot /Applications. Schakel dit in bij Systeeminstellingen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplikacja wymaga dostępu do odczytu/zapisu w /Applications. Włącz w Ustawieniach systemowych."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O app precisa de acesso de leitura/gravação em /Applications. Ative nas Configurações."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Приложению требуется доступ к /Applications. Включите в настройках."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "แอปต้องการสิทธิ์อ่าน/เขียนใน /Applications โปรดเปิดใช้งานในการตั้งค่าระบบ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Uygulamanın /Applications klasörüne okuma/yazma erişimine ihtiyacı var. Lütfen Sistem Ayarlarında etkinleştirin."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ứng dụng cần quyền đọc/ghi vào /Applications. Vui lòng bật trong Cài đặt hệ thống."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "应用需要读写 /Applications 目录才能工作。请在系统设置中开启。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "應用程式需要讀寫 /Applications 目錄才能運作。請在系統設定中開啟。"
          }
        }
      }
    },

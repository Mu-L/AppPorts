        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze app is gemigreerd naar externe opslag maar niet vergrendeld. In-app updates kunnen de externe app verwijderen. Het wordt aanbevolen om terug te verplaatsen en opnieuw te migreren in vergrendelde modus."
          }

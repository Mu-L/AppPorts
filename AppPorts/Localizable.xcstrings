    "macOS 15.1+ жФѓжМБе∞Ж App Store еЇФзФ®еЃЙи£ЕеИ∞е§ЦйГ®з£БзЫШгАВ\\n\\nиѓЈеЬ® App Store вЖТ иЃЊзљЃдЄ≠еЛЊйАЙгАМе∞Же§ІеЮЛ App дЄЛиљљеєґеЃЙи£ЕеИ∞зЛђзЂЛз£БзЫШгАНпЉМеєґйАЙжЛ©ељУеЙНе§ЦйГ®й©±еК®еЩ®гАВ\\n\\nиЃЊзљЃеЃМжИРеРОзВєеЗїгАМжИСеЈ≤иЃЊзљЃгАНпЉМAppPorts дЉЪиЗ™еК®еИЫеїЇ Applications зЫЃељХеєґж£АжµЛзЃ°зРЖињЩдЇЫеЇФзФ®гАВ": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS 15.1+ supports installing App Store apps to external disks.\n\nPlease go to App Store вЖТ Settings and check \"Download and install large apps to a separate disk\", then select your current external drive.\n\nAfter setup, click \"I've Set It Up\" and AppPorts will automatically create the Applications directory and detect these apps."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS 15.1+ жФѓжМБе∞Ж App Store еЇФзФ®еЃЙи£ЕеИ∞е§ЦйГ®з£БзЫШгАВ\n\nиѓЈеЬ® App Store вЖТ иЃЊзљЃдЄ≠еЛЊйАЙгАМе∞Же§ІеЮЛ App дЄЛиљљеєґеЃЙи£ЕеИ∞зЛђзЂЛз£БзЫШгАНпЉМеєґйАЙжЛ©ељУеЙНе§ЦйГ®й©±еК®еЩ®гАВ\n\nиЃЊзљЃеЃМжИРеРОзВєеЗїгАМжИСеЈ≤иЃЊзљЃгАНпЉМAppPorts дЉЪиЗ™еК®еИЫеїЇ Applications зЫЃељХеєґж£АжµЛзЃ°зРЖињЩдЇЫеЇФзФ®гАВ"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS 15.1+ жФѓжМБе∞Ж App Store еЇФзФ®еЃЙи£ЕеИ∞е§ЦйГ®з£БзЫШгАВ\n\nиѓЈеЬ® App Store вЖТ иЃЊзљЃдЄ≠еЛЊйАЙгАМе∞Же§ІеЮЛ App дЄЛиљљеєґеЃЙи£ЕеИ∞зЛђзЂЛз£БзЫШгАНпЉМеєґйАЙжЛ©ељУеЙНе§ЦйГ®й©±еК®еЩ®гАВ\n\nиЃЊзљЃеЃМжИРеРОзВєеЗїгАМжИСеЈ≤иЃЊзљЃгАНпЉМAppPorts дЉЪиЗ™еК®еИЫеїЇ Applications зЫЃељХеєґж£АжµЛзЃ°зРЖињЩдЇЫеЇФзФ®гАВ"

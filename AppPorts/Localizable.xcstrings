        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta app esta basada en el framework Electron y soporta actualizaciones automaticas. Despues de migrar al almacenamiento externo, las actualizaciones dentro de la app pueden causar la perdida de la app externa. Se recomienda la migracion bloqueada."
          }

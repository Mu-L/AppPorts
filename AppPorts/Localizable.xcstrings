    "иѓ•зЫЃељХдљНдЇОж≤ЩзЫТеЃєеЩ®еЖЕпЉМmacOS дЉЪж†°й™МеЃєеЩ®еЃМжХіжАІгАВињБзІїдЉЪеѓЉиЗіеЇФзФ®еРѓеК®еі©жЇГгАВ": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This directory is inside a sandbox container. macOS validates container integrity. Migration will cause the app to crash on launch."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "гБУгБЃгГЗгВ£гГђгВѓгГИгГ™гБѓгВµгГ≥гГЙгГЬгГГгВѓгВєгВ≥гГ≥гГЖгГКеЖЕгБЂгБВгВКгБЊгБЩгАВmacOSгБѓгВ≥гГ≥гГЖгГКгБЃжХіеРИжАІгВТж§Ьи®ЉгБЧгБЊгБЩгАВзІїи°МгБЩгВЛгБ®гВҐгГЧгГ™гБЃиµЈеЛХжЩВгБЂгВѓгГ©гГГгВЈгГ•гБЧгБЊгБЩгАВ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "мЭі лФФл†ЙнЖ†л¶ђлКФ мГМлУЬл∞ХмК§ мї®нЕМмЭілДИ лВілґАмЧР мЮИмКµлЛИлЛ§. macOSлКФ мї®нЕМмЭілДИ лђік≤∞мД±мЭД к≤Ам¶ЭнХ©лЛИлЛ§. лІИмЭікЈЄл†ИмЭімЕШнХШл©і мХ±мЭі мЛЬмЮС мЛЬ мґ©лПМнХ©лЛИлЛ§."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Verzeichnis befindet sich in einem Sandbox-Container. macOS ueberprueft die Container-Integritaet. Eine Migration fuehrte zum Absturz der App beim Start."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce repertoire se trouve dans un conteneur sandbox. macOS verifie l'integrite du conteneur. La migration provoquerait un plantage de l'application au demarrage."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este directorio esta dentro de un contenedor sandbox. macOS verifica la integridad del contenedor. La migracion haria que la app se cierre inesperadamente al iniciar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Etot katalog nakhoditsya vnutri konteynera pesochnitsy. macOS proveryayet tselostnost konteynera. Migratsiya privedyot k sboyu prilozheniya pri zapuske."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "hada aldaleel fi dakhil hafizat alrimal. yatahadat macOS min salamat alhafizat. sayajalt alttahil alttatbiq eind albash."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "drectory ni yu nai sandbox container. macOS ja truatsob khwam sombat khong container. kan yai ja thang hai app lom khi lot"

    "将庞大的应用程序一键迁移至外部移动硬盘，释放宝贵的 Mac 本地空间。": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "نقل التطبيقات الكبيرة إلى محرك أقراص خارجي بنقرة واحدة، مما يوفر مساحة Mac قيمة."
          }
        },
        "br": {
          "stringUnit": {
            "state": "translated",
            "value": "⠠⠕⠝⠑⠤⠉⠇⠊⠉⠅ ⠍⠊⠛⠗⠁⠞⠑ ⠇⠁⠗⠛⠑ ⠁⠏⠏⠎ ⠞⠕ ⠑⠭⠞⠑⠗⠝⠁⠇ ⠙⠗⠊⠧⠑⠂ ⠋⠗⠑⠑⠊⠝⠛ ⠥⠏ ⠧⠁⠇⠥⠁⠃⠇⠑ ⠠⠍⠁⠉ ⠎⠏⠁⠉⠑⠲"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Migrieren Sie große Apps mit einem Klick auf ein externes Laufwerk und geben Sie wertvollen Mac-Speicherplatz frei."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "One-click migrate large apps to external drive, freeing up valuable Mac space."
          }
        },
        "eo": {
          "stringUnit": {
            "state": "translated",
            "value": "Unuklaka migrado de grandaj aplikaĵoj al ekstera disko, liberigante valoran spacon de Mac."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Migra grandes apps a una unidad externa con un solo clic, liberando espacio en tu Mac."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Migrez les grandes applications vers un disque externe en un clic, libérant de l'espace sur Mac."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बड़े ऐप्स को बाहरी ड्राइव में माइग्रेट करें और मैक स्पेस खाली करें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Migrasikan aplikasi besar ke drive eksternal dengan sekali klik, membebaskan ruang Mac yang berharga."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Migra grandi app su unità esterna con un clic, liberando spazio prezioso su Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ワンクリックで大きなアプリを外部ドライブに移行し、Macのスペースを解放します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "원클릭으로 대용량 앱을 외부 드라이브로 마이그레이션하여 귀중한 Mac 공간을 확보하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Migreer grote apps met één klik naar een externe schijf en maak waardevolle Mac-ruimte vrij."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jednym kliknięciem przenieś duże aplikacje na dysk zewnętrzny, zwalniając cenne miejsce na Macu."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Migre apps grandes para unidade externa com um clique, liberando espaço no Mac."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Миграция больших приложений на внешний диск в один клик, освобождая место на Mac."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ย้ายแอปขนาดใหญ่ไปยังไดรฟ์ภายนอกได้ในคลิกเดียว เพิ่มพื้นที่ว่างอันมีค่าให้กับ Mac ของคุณ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Büyük uygulamaları tek tıklamayla harici sürücüye taşıyın, değerli Mac alanını boşaltın."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Di chuyển các ứng dụng lớn sang ổ đĩa ngoài chỉ bằng một cú nhấp chuột, giải phóng không gian Mac quý giá."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将庞大的应用程序一键迁移至外部移动硬盘，释放宝贵的 Mac 本地空间。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將龐大的應用程式一鍵遷移至外接硬碟，釋放寶貴的 Mac 本地空間。"
          }
        }
      }
    },

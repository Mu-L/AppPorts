        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu dizin bir sandbox konteynerinin icinde. macOS konteyner butunlugunu dogrular. Tasima uygulamanin baslatilmasinda cokmesine neden olur."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thu muc nay nam trong sandbox container. macOS xac minh tinh toan ven cua container. Di chuyen se khiem ung dung crash khi khoi dong."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Direktori ini berada di dalam wadah sandbox. macOS memvalidasi integritas wadah. Migrasi akan menyebabkan aplikasi mogok saat diluncurkan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa directory si trova all'interno di un contenitore sandbox. macOS verifica l'integrita del contenitore. La migrazione causerebbe il crash dell'app all'avvio."
          }
